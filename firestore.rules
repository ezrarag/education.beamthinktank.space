rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function membershipDoc() {
      return get(/databases/$(database)/documents/ngoMemberships/$(request.auth.uid));
    }

    function hasMembership() {
      return isAuthenticated() && exists(/databases/$(database)/documents/ngoMemberships/$(request.auth.uid));
    }

    function memberRole() {
      return hasMembership() ? membershipDoc().data.role : null;
    }

    function isResearcher() {
      return hasMembership() && (memberRole() == 'researcher' || memberRole() == 'admin');
    }

    function isAdmin() {
      return hasMembership() && memberRole() == 'admin';
    }

    match /ngoMemberships/{userId} {
      allow read: if isOwner(userId) || isResearcher();
      allow create, update: if isOwner(userId);
    }

    match /educationEnrollments/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /educationPrograms/{programId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /educationGrantApplications/{grantId} {
      allow read, create, update, delete: if isResearcher();
    }

    match /educationRecordsRequests/{requestId} {
      allow read: if true;
      allow create, update, delete: if isResearcher();
    }

    match /educationAdvocacy/{contactId} {
      allow read, create, update, delete: if isResearcher();
    }

    match /educationResearchBriefs/{briefId} {
      allow read, create, update, delete: if isResearcher();
    }
  }
}
